model Gift {
  id              Int      @id @default(autoincrement())
  senderTableId   Int
  receiverTableId Int
  productId       Int
  status          String   @default("pending") // pending, accepted, rejected
  message         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  senderTable     Table    @relation("SenderTable", fields: [senderTableId], references: [id])
  receiverTable   Table    @relation("ReceiverTable", fields: [receiverTableId], references: [id])
  product         Product  @relation(fields: [productId], references: [id])
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
