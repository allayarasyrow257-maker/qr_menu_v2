model Category {
  id        Int       @id @default(autoincrement())
  name      Json      // { en: "Drinks", tr: "İçecekler", ar: "مشروبات" }
  image     String?
  icon      String?   // Small pill icon shown on the customer category tabs
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id          Int         @id @default(autoincrement())
  name        Json        // { en: "Cola", tr: "Kola", ar: "كولا" }
  description Json?       // multi-language description
  price       Decimal     @db.Decimal(10, 2)
  image       String?
  categoryId  Int
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  available   Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  comboItems  ComboItem[]
  giftItems   Gift[]
}

model Combo {
  id          Int         @id @default(autoincrement())
  name        Json        // multi-language
  description Json?
  price       Decimal     @db.Decimal(10, 2)
  image       String?
  available   Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       ComboItem[]
  orderItems  OrderItem[]
}

model ComboItem {
  id        Int     @id @default(autoincrement())
  comboId   Int
  productId Int
  quantity  Int     @default(1)
  combo     Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

